{
	"name": "marketforge",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"dev": "dotenv -e .env.local -- vite dev",
		"build": "SVELTEKIT_BUILD_PLACEHOLDER_DB=1 vite build",
		"preview": "dotenv -e .env.local -- vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"icons:generate": "tsx scripts/generate-icons.ts",
		"prebuild": "pnpm icons:generate",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"commitlint": "commitlint --edit",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:local": "dotenv -e .env.local -- playwright test",
		"test:e2e:ui": "playwright test --ui",
		"db:generate": "dotenv -e .env.local -- drizzle-kit generate",
		"db:migrate": "tsx scripts/db-migrate.ts",
		"db:studio": "dotenv -e .env.local -- drizzle-kit studio",
		"db:seed": "dotenv -e .env.local -- tsx scripts/seed-dev.ts",
		"db:reset": "docker compose down -v && docker compose up -d && sleep 5 && pnpm db:migrate && pnpm db:seed",
		"stripe:listen": "stripe listen --forward-to localhost:5173/api/webhooks/stripe",
		"backup:db": "bash scripts/backup-postgres.sh"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.2",
		"@biomejs/biome": "^2.4.12",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@iconify/svelte": "^5.2.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"dotenv": "^17.4.2",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"msw": "^2.13.4",
		"pino-pretty": "^13.1.3",
		"sv-agentation": "^0.2.6",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"svg-to-svelte": "^2.2.1",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": "24.14.1"
	},
	"dependencies": {
		"@better-auth/passkey": "^1.6.5",
		"@humanspeak/svelte-motion": "^0.2.0",
		"@sentry/sveltekit": "^10.49.0",
		"better-auth": "^1.6.5",
		"drizzle-orm": "^0.45.2",
		"marked": "^18.0.1",
		"pino": "^10.3.1",
		"postgres": "^3.4.9",
		"resend": "^6.12.0",
		"stripe": "^22.0.2",
		"sveltekit-superforms": "^2.30.1",
		"zod": "^4.3.6"
	}
}
