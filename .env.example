# MarketForge — copy to .env.local and fill in values (never commit secrets)

# App
NODE_ENV=development
PUBLIC_APP_URL=http://localhost:5173
LOG_LEVEL=debug

# Database (PostgreSQL 16)
DATABASE_URL=postgres://marketforge:marketforge@localhost:5433/marketforge
DIRECT_DATABASE_URL=postgres://marketforge:marketforge@localhost:5433/marketforge

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:5173

# Stripe
STRIPE_SECRET_KEY=
PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=MarketForge <onboarding@resend.dev>
# Inbound address for /contact form (same domain often required by Resend)
MARKETFORGE_CONTACT_INBOX=

# Sentry
SENTRY_DSN=
PUBLIC_SENTRY_DSN=

# Outbox cron endpoint (Bearer-auth header on POST /api/cron/outbox).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=

# Plausible (Phase 7)
PUBLIC_PLAUSIBLE_DOMAIN=
PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/script.js
# Optional — for server-side events (e.g. Stripe webhooks) to Plausible
PLAUSIBLE_API_KEY=

# Dev / staging only — never set in production
DEV_TEST_PASSWORD=
